# ====== SERVER ======
PORT=3000
PUBLIC_URL=https://your-domain.com        # URL public HTTPS (webhook + callback ZaloPay phai goi vao day)

# ====== ZALO OA (https://developers.zalo.me) ======
ZALO_APP_ID=your_app_id
ZALO_APP_SECRET=your_app_secret           # App Secret Key (dung de refresh token)
ZALO_OA_SECRET=your_oa_secret_key         # OA Secret Key (dung de verify webhook) - KHAC app secret
ZALO_OA_REFRESH_TOKEN=your_refresh_token  # Lay tu buoc OAuth lan dau (xem README)

# ====== ZALOPAY (https://docs.zalopay.vn) - dien gia tri SANDBOX de test ======
