ZALOPAY_ENV=sandbox                       # sandbox | production

# ====== ADMIN (bao ve API quan tri menu/tuyen/don) ======
ADMIN_API_KEY=doi-thanh-chuoi-bi-mat-cua-anh

# ====== THONG TIN NGUOI BAN (in tren hoa don) ======
SELLER_TAX_CODE=0312345678
SELLER_NAME=CONG TY TNHH CA PHE ANCHOR
SELLER_ADDRESS=123 Nguyen Hue, Q1, TP.HCM
SELLER_PHONE=02812345678
SELLER_BANK_ACCOUNT=
SELLER_BANK_NAME=

# ====== HOA DON DIEN TU (HDDT khoi tao tu may tinh tien) ======
EINVOICE_ENABLED=false                 # bat khi da ky hop dong NCC
EINVOICE_PROVIDER=mock                 # mock | rest (VNPT/Viettel/MISA/EasyInvoice)
EINVOICE_API_URL=https://api-provider.example
EINVOICE_USERNAME=
EINVOICE_PASSWORD=
EINVOICE_TEMPLATE_CODE=1               # mau so hoa don (dang ky voi CQT)
EINVOICE_SERIES=C25MAA                 # ky hieu (M = hoa don tu may tinh tien)
EINVOICE_DEFAULT_VAT=8                 # % VAT mac dinh (an uong)
EINVOICE_PRICE_INCLUDES_VAT=true       # gia menu da gom VAT chua?

# ====== POS & PHAN CUNG ======
PRINTER_TYPE=epson                     # epson | star
PRINTER_INTERFACE=tcp://192.168.1.100  # tcp://ip | usb | printer:Ten_may_in
PRINTER_OPEN_DRAWER=true               # mo ket khi thu tien mat
POS_WEBHOOK_SECRET=doi-chuoi-bi-mat    # xac thuc webhook tu POS ngoai
